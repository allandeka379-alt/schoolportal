# Direct connection — used by Prisma Migrate.
DIRECT_DATABASE_URL=postgresql://hha:hha@localhost:5432/hha?schema=public

# Pooled connection — used at runtime. In prod, point at PgBouncer or
# Supabase's pooled URL; locally the two are the same.
DATABASE_URL=postgresql://hha:hha@localhost:5432/hha?schema=public&pgbouncer=true&connection_limit=1
