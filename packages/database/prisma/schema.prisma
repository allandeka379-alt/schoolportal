// =============================================================================
//  10. SYSTEM — files, audit, background jobs
// =============================================================================

/// Every uploaded asset — avatars, assignments, submissions, slips, receipts.
/// Storage is S3-compatible (MinIO in dev, R2/S3 in prod).
model FileAsset {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String?  @db.Uuid
  storageKey      String   @unique
  bucket          String
  contentType     String
  sizeBytes       BigInt
  checksumSha256  String
  originalFilename String?
  kind            FileKind @default(OTHER)
  uploadedById    String?  @db.Uuid
  virusScanStatus VirusScanStatus @default(PENDING)
  virusScanDetail String?
  isPublic        Boolean  @default(false)
  createdAt       DateTime @default(now())

  schoolCrestOf       School? @relation("SchoolCrest")
  schoolLetterheadOf  School? @relation("SchoolLetterhead")
  userAvatarOf        User[]  @relation("UserAvatar")
  houseCrestOf        House[] @relation("HouseCrest")
  assignmentAttachments AssignmentAttachment[]
  submissionAttachments SubmissionAttachment[]
  submissionFeedbackAudio Submission[] @relation("SubmissionFeedbackAudio")
  reportPdfs          ReportCard[]    @relation("ReportCardPdf")
  slipOriginals       BankSlipUpload[] @relation("SlipOriginal")
  slipEnhanced        BankSlipUpload[] @relation("SlipEnhanced")
  paymentReceipts     Payment[]        @relation("PaymentReceipt")
  messageAttachments  MessageAttachment[]
  announcementAttachments AnnouncementAttachment[]
  resourcePrimary     Resource[]       @relation("ResourcePrimary")
  admissionDocuments  AdmissionDocument[]
  cpdCertificates     CpdEntry[]

  @@index([schoolId, kind])
  @@map("file_asset")
}

/// Immutable audit trail — every privileged action, every mark change, every
/// fee adjustment. Subject to Section 10's "complete audit trail" requirement.
model AuditLog {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String?  @db.Uuid
  actorUserId     String?  @db.Uuid
  actorIp         String?
  actorUserAgent  String?
  action          String
  resourceType    String
  resourceId      String?
  before          Json?
  after           Json?
  metadata        Json?
  succeeded       Boolean  @default(true)
  severity        AuditSeverity @default(INFO)
  createdAt       DateTime @default(now())

  school          School?  @relation(fields: [schoolId], references: [id])
  actor           User?    @relation(fields: [actorUserId], references: [id])

  @@index([schoolId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_log")
}

