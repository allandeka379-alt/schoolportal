model InvoiceLineItem {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId       String   @db.Uuid
  label           String
  amount          Decimal  @db.Decimal(12, 2)
  quantity        Int      @default(1)
  sourceComponentId String? @db.Uuid
  displayOrder    Int      @default(0)

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_line_item")
}

model InvoiceReminder {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId       String   @db.Uuid
  tone            ReminderTone
  sentAt          DateTime @default(now())
  channel         CommunicationChannel
  sentById        String?  @db.Uuid

  invoice         Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_reminder")
}

model Payment {
  id              String   @id @default(uuid()) @db.Uuid
  invoiceId       String?  @db.Uuid
  studentId       String   @db.Uuid
  initiatedById   String   @db.Uuid
  method          PaymentMethod
  currency        Currency
  amount          Decimal  @db.Decimal(12, 2)
  amountReceived  Decimal? @db.Decimal(12, 2)
  reference       String   @unique
  externalReference String?
  status          PaymentStatus @default(PENDING_VERIFICATION)
  gatewayProvider String?
  gatewayPayload  Json?
  bankSlipId      String?  @unique @db.Uuid
  reconciledWithLineId String? @unique @db.Uuid
  verifiedAt      DateTime?
  failedReason    String?
  receiptAssetId  String?  @db.Uuid
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  invoice         Invoice? @relation(fields: [invoiceId], references: [id])
  bankSlip        BankSlipUpload? @relation(fields: [bankSlipId], references: [id])
  reconciledWithLine BankStatementLine? @relation(fields: [reconciledWithLineId], references: [id])
  receiptAsset    FileAsset? @relation("PaymentReceipt", fields: [receiptAssetId], references: [id])

  @@index([studentId, status])
  @@index([method, status])
  @@index([createdAt])
  @@map("payment")
}

model SchoolBankAccount {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  bank            Bank
  accountName     String
  accountNumber   String
  branchName      String?
  branchCode      String?
  currency        Currency
  swiftCode       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  school          School   @relation(fields: [schoolId], references: [id])
  statementLines  BankStatementLine[]

  @@unique([schoolId, bank, accountNumber])
  @@map("school_bank_account")
}

/// Each line imported from a bank statement (CSV, OFX, API). Reconciliation
/// matches these against payments claimed through slip uploads.
model BankStatementLine {
  id              String   @id @default(uuid()) @db.Uuid
  bankAccountId   String   @db.Uuid
  postedOn        DateTime @db.Date
  valueOn         DateTime? @db.Date
  direction       StatementDirection
  amount          Decimal  @db.Decimal(12, 2)
  currency        Currency
  narration       String
  counterpartyName String?
  counterpartyReference String?
  externalTransactionId String?
  reconciled      Boolean  @default(false)
  createdAt       DateTime @default(now())

  bankAccount     SchoolBankAccount @relation(fields: [bankAccountId], references: [id])
  reconciledWithPayment Payment?

  @@index([bankAccountId, postedOn])
  @@index([reconciled])
  @@map("bank_statement_line")
}

// =============================================================================
//  8. DOCUMENT INTELLIGENCE — bank-slip OCR
// =============================================================================

/// An uploaded bank-deposit slip. The lifecycle is:
///   UPLOADED → OCR_COMPLETE → PARSED → VERIFIED → RECONCILED   (or FAILED/REJECTED)
model BankSlipUpload {
  id              String   @id @default(uuid()) @db.Uuid
  uploadedById    String   @db.Uuid
  studentId       String   @db.Uuid
  originalAssetId String   @db.Uuid
  enhancedAssetId String?  @db.Uuid
  status          SlipStatus @default(UPLOADED)
  detectedBank    Bank?
  ocrProvider     OcrProvider?
  rawOcrPayload   Json?
  parsedFields    Json?
  parsedAmount    Decimal? @db.Decimal(12, 2)
  parsedCurrency  Currency?
  parsedAccountNumber String?
  parsedAccountName String?
  parsedReference String?
  parsedDepositedOn DateTime? @db.Date
  parsedTellerStamp String?
  confidenceScore Decimal? @db.Decimal(5, 2)
  failureReason   String?
  reviewedById    String?  @db.Uuid
  reviewedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  originalAsset   FileAsset @relation("SlipOriginal", fields: [originalAssetId], references: [id])
  enhancedAsset   FileAsset? @relation("SlipEnhanced", fields: [enhancedAssetId], references: [id])
  payment         Payment?
  events          BankSlipEvent[]

  @@index([status])
  @@index([studentId])
  @@map("bank_slip_upload")
}

/// Event log — makes the 6-step pipeline fully debuggable and auditable.
model BankSlipEvent {
  id              String   @id @default(uuid()) @db.Uuid
  slipId          String   @db.Uuid
  step            SlipPipelineStep
  outcome         SlipStepOutcome
  durationMs      Int?
  detail          Json?
  createdAt       DateTime @default(now())

  slip            BankSlipUpload @relation(fields: [slipId], references: [id], onDelete: Cascade)

  @@index([slipId, createdAt])
  @@map("bank_slip_event")
}

