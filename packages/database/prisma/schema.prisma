  announcement    Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user            User         @relation(fields: [userId], references: [id])

  @@unique([announcementId, userId])
  @@map("announcement_acknowledgement")
}

/// Direct messaging — teacher ↔ student ↔ guardian — with guardrails.
model MessageThread {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  subject         String?
  kind            ThreadKind @default(DIRECT)
  moderated       Boolean  @default(true)
  createdAt       DateTime @default(now())
  lastMessageAt   DateTime @default(now())

  participants    ThreadParticipant[]
  messages        Message[]

  @@index([schoolId, lastMessageAt])
  @@map("message_thread")
}

model ThreadParticipant {
  id              String   @id @default(uuid()) @db.Uuid
  threadId        String   @db.Uuid
  userId          String   @db.Uuid
  role            ParticipantRole @default(MEMBER)
  mutedUntil      DateTime?
  leftAt          DateTime?

  thread          MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("thread_participant")
}

model Message {
  id              String   @id @default(uuid()) @db.Uuid
  threadId        String   @db.Uuid
  senderId        String   @db.Uuid
  body            String
  moderationStatus ModerationStatus @default(APPROVED)
  moderatedBy     String?  @db.Uuid
  sentAt          DateTime @default(now())
  editedAt        DateTime?
  deletedAt       DateTime?

  thread          MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender          User          @relation("MessageSender", fields: [senderId], references: [id])
  reads           MessageRead[]
  attachments     MessageAttachment[]

  @@index([threadId, sentAt])
  @@map("message")
}

model MessageRead {
  messageId       String   @db.Uuid
  userId          String   @db.Uuid
  readAt          DateTime @default(now())

  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@map("message_read")
}

model MessageAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  messageId       String   @db.Uuid
  assetId         String   @db.Uuid

  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  asset           FileAsset @relation(fields: [assetId], references: [id])

  @@map("message_attachment")
}

model Notification {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  kind            NotificationKind
  title           String
  body            String?
  deeplink        String?
  deliveredAt     DateTime @default(now())
  readAt          DateTime?
  channel         CommunicationChannel @default(IN_APP)
  metadata        Json?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([userId, kind])
  @@map("notification")
}

model PushToken {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @db.Uuid
  platform        PushPlatform
  tokenHash       String   @unique
  deviceLabel     String?
  createdAt       DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  revokedAt       DateTime?

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_token")
}

