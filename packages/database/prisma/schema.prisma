// =============================================================================
//  HHA Portal — Prisma schema
//
//  The schema is intentionally normalised and audit-friendly. Every change a
//  teacher, bursar, or administrator makes is attributable and reversible.
//
//  Sections below follow the 16-section proposal:
//    1. Identity & Access           (Section 10)
//    2. Organisational structure    (Section 6)
//    3. People                      (Sections 4-6, 9)
//    4. Academic workspace          (Sections 4-5)
//    5. Resources / Library         (Section 4)
//    6. Communications              (Section 8)
//    7. Fees & Payments             (Section 7)
//    8. Document intelligence       (Section 7)
//    9. Well-being & community      (Section 4 — Quiet Room, Alumni)
//   10. Audit & system tables       (Section 10)
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  output          = "../generated/client"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pgcrypto, citext, pg_trgm]
}

// =============================================================================
//  1. IDENTITY & ACCESS
// =============================================================================

/// Top-level tenant. The system starts with one (HHA) but is designed so a
/// group of schools could share an installation if the Board ever chose to.
model School {
  id              String   @id @default(uuid()) @db.Uuid
  slug            String   @unique @db.Citext
  legalName       String
  shortName       String
  motto           String?
  addressLine1    String?
  addressLine2    String?
  city            String?
  province        String?
  country         String   @default("ZW")
  phone           String?
  email           String?  @db.Citext
  websiteUrl      String?
  crestAssetId    String?  @unique @db.Uuid
  letterheadAssetId String? @unique @db.Uuid
  timezone        String   @default("Africa/Harare")
  defaultLocale   Locale   @default(EN)
  supportedLocales Locale[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  crestAsset      FileAsset? @relation("SchoolCrest", fields: [crestAssetId], references: [id])
  letterheadAsset FileAsset? @relation("SchoolLetterhead", fields: [letterheadAssetId], references: [id])

  users           User[]
  students        Student[]
  staff           StaffProfile[]
  guardians       GuardianProfile[]
  academicYears   AcademicYear[]
  forms           Form[]
  houses          House[]
  subjects        Subject[]
  feeStructures   FeeStructure[]
  announcements   Announcement[]
  auditLogs       AuditLog[]
  bankAccounts    SchoolBankAccount[]
  alumni          AlumniProfile[]

  @@index([country])
  @@map("school")
}

/// Stable identity. A user is a person; their *roles* determine what they see.
/// A single person can be, for example, both staff and a parent — there is one
/// User row and two role membership rows.
model User {
  id              String     @id @default(uuid()) @db.Uuid
  schoolId        String     @db.Uuid
  email           String     @db.Citext
  emailVerifiedAt DateTime?
  phoneE164       String?
  phoneVerifiedAt DateTime?
  firstName       String
  middleName      String?
  lastName        String
  displayName     String?
  preferredLocale Locale     @default(EN)
  status          UserStatus @default(PENDING)
  avatarAssetId   String?    @db.Uuid
  lastSignInAt    DateTime?
  passwordResetRequiredAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  school          School            @relation(fields: [schoolId], references: [id], onDelete: Restrict)
  avatarAsset     FileAsset?        @relation("UserAvatar", fields: [avatarAssetId], references: [id])
  credentials     UserCredential?
  mfaMethods      MfaMethod[]
  sessions        Session[]
  roleMemberships RoleMembership[]
  studentProfile  Student?
  staffProfile    StaffProfile?
  guardianProfile GuardianProfile?
  sentMessages    Message[]         @relation("MessageSender")
  messageReads    MessageRead[]
  announcementAcks AnnouncementAcknowledgement[]
  authoredAnnouncements Announcement[] @relation("AnnouncementAuthor")
  auditLogs       AuditLog[]
  notifications   Notification[]
  pushTokens      PushToken[]
  consentRecords  ConsentRecord[]

  @@unique([schoolId, email])
  @@unique([schoolId, phoneE164])
  @@index([schoolId, status])
  @@map("user")
}

/// Passwords live in their own table so they can be rotated, archived, and
/// never accidentally loaded into logs with the rest of the user row.
model UserCredential {
  userId          String   @id @db.Uuid
  passwordHash    String
  algorithm       String   @default("argon2id")
  rotatedAt       DateTime @default(now())
  failedAttempts  Int      @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_credential")
}

/// Two-factor auth methods (Section 10 — mandatory for staff, optional for
/// parents/students). TOTP stored encrypted; webauthn credentials stored raw.
model MfaMethod {
  id              String       @id @default(uuid()) @db.Uuid
  userId          String       @db.Uuid
  type            MfaType
  label           String?
  secretCiphertext String?
  webauthnCredentialId String?
  webauthnPublicKey    String?
  webauthnCounter      Int?     @default(0)
  lastUsedAt      DateTime?
  verifiedAt      DateTime?
  createdAt       DateTime     @default(now())

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, label])
  @@map("mfa_method")
}

/// Authenticated sessions. We keep a server-side record so "sign out everywhere"
/// is a hard guarantee rather than a best-effort.
model Session {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  tokenHash       String    @unique
  ipAddress       String?
  userAgent       String?
  deviceLabel     String?
  deviceTrusted   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  lastActiveAt    DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  revokedReason   String?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("session")
}

/// Role-based access control. Roles are a small, managed set; *permissions*
/// (verb + resource scopes) are granted to roles in code — not freely.
model Role {
  id              String    @id @default(uuid()) @db.Uuid
  key             RoleKey   @unique
  name            String
  description     String?
  createdAt       DateTime  @default(now())

  memberships     RoleMembership[]

  @@map("role")
}

/// Binds a user to a role. A grandparent-paying-fees-but-not-seeing-reports is
/// modelled as a Guardian role with scoped permissions on the relationship row.
model RoleMembership {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  roleId          String    @db.Uuid
  scopeType       RoleScopeType @default(SCHOOL)
  scopeId         String?   @db.Uuid
  grantedAt       DateTime  @default(now())
  grantedBy       String?   @db.Uuid
  revokedAt       DateTime?
  revokedBy       String?   @db.Uuid

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role            Role      @relation(fields: [roleId], references: [id])

  @@unique([userId, roleId, scopeType, scopeId])
  @@index([userId])
  @@map("role_membership")
}

/// For parents/students who accept privacy notices, terms, and marketing
/// preferences — stored as a stream of immutable consent events.
model ConsentRecord {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @db.Uuid
  documentKey     String
  documentVersion String
  locale          Locale
  grantedAt       DateTime       @default(now())
  withdrawnAt     DateTime?
  ipAddress       String?

  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, documentKey])
  @@map("consent_record")
}

// =============================================================================
//  2. ORGANISATIONAL STRUCTURE
// =============================================================================

/// e.g. 2026 — bounds term dates, report generation, ZIMSEC exports.
model AcademicYear {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  label           String
  startsOn        DateTime @db.Date
  endsOn          DateTime @db.Date
  isCurrent       Boolean  @default(false)
  createdAt       DateTime @default(now())

  school          School   @relation(fields: [schoolId], references: [id])
  terms           Term[]
  enrolments      Enrolment[]
  feeStructures   FeeStructure[]

  @@unique([schoolId, label])
  @@index([schoolId, isCurrent])
  @@map("academic_year")
}

/// Term 1, 2, 3 within an academic year. Assessments/reports hang off terms.
model Term {
  id              String   @id @default(uuid()) @db.Uuid
  academicYearId  String   @db.Uuid
  ordinal         Int
  label           String
  startsOn        DateTime @db.Date
  endsOn          DateTime @db.Date
  reportReleaseDate DateTime?
  createdAt       DateTime @default(now())

  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  assignments     Assignment[]
  gradebookEntries GradebookEntry[]
  reports         ReportCard[]
  invoices        Invoice[]

  @@unique([academicYearId, ordinal])
  @@map("term")
}

/// Form = grade (Form 1..6). The proposal calls for form-specific channels,
/// form-teacher sign-off on reports, etc., so forms are first-class.
model Form {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  level           Int
  label           String
  description     String?
  createdAt       DateTime @default(now())

  school          School   @relation(fields: [schoolId], references: [id])
  streams         Stream[]
  feeStructures   FeeStructure[]

  @@unique([schoolId, level, label])
  @@map("form")
}

/// Stream = a specific class within a form (e.g. "Form 3 Blue"). Homeroom-level.
model Stream {
  id              String   @id @default(uuid()) @db.Uuid
  formId          String   @db.Uuid
  code            String
  formTeacherId   String?  @db.Uuid
  roomCode        String?
  capacity        Int?
  createdAt       DateTime @default(now())

  form            Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formTeacher     StaffProfile? @relation("StreamFormTeacher", fields: [formTeacherId], references: [id])
  enrolments      Enrolment[]
  courseOfferings CourseOffering[]
  timetableSlots  TimetableSlot[]

  @@unique([formId, code])
  @@map("stream")
}

/// Houses drive house points, inter-house competition, and the "Study Streak"
/// gamification layer described in Section 4.
model House {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  name            String
  crestAssetId    String?  @db.Uuid
  colorHex        String?
  mottoLine       String?
  createdAt       DateTime @default(now())

  school          School   @relation(fields: [schoolId], references: [id])
  crestAsset      FileAsset? @relation("HouseCrest", fields: [crestAssetId], references: [id])
  memberships     HouseMembership[]
  points          HousePointEntry[]

  @@unique([schoolId, name])
  @@map("house")
}

model HouseMembership {
  id              String   @id @default(uuid()) @db.Uuid
  houseId         String   @db.Uuid
  studentId       String   @db.Uuid
  joinedAt        DateTime @default(now())
  leftAt          DateTime?

  house           House    @relation(fields: [houseId], references: [id])
  student         Student  @relation(fields: [studentId], references: [id])

  @@unique([houseId, studentId])
  @@map("house_membership")
}

model HousePointEntry {
  id              String   @id @default(uuid()) @db.Uuid
  houseId         String   @db.Uuid
  studentId       String?  @db.Uuid
  points          Int
  reason          String
  awardedById     String   @db.Uuid
  awardedAt       DateTime @default(now())

  house           House    @relation(fields: [houseId], references: [id])
  student         Student? @relation(fields: [studentId], references: [id])
  awardedBy       StaffProfile @relation(fields: [awardedById], references: [id])

  @@index([houseId, awardedAt])
  @@map("house_point_entry")
}

// =============================================================================
//  3. PEOPLE — Students, Staff, Guardians
// =============================================================================

model Student {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  schoolId        String   @db.Uuid
  admissionNo     String
  dateOfBirth     DateTime @db.Date
  gender          Gender?
  nationalIdHash  String?
  religion        String?
  nationality     String?
  medicalSummaryEncrypted String?
  admittedOn      DateTime @db.Date
  graduatedOn     DateTime?
  status          StudentStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School   @relation(fields: [schoolId], references: [id])
  enrolments      Enrolment[]
  submissions     Submission[]
  gradebookEntries GradebookEntry[]
  reportCards     ReportCard[]
  attendance      AttendanceRecord[]
  invoices        Invoice[]
  guardians       StudentGuardian[]
  houseMemberships HouseMembership[]
  pointsEarned    HousePointEntry[]
  studyStreaks    StudyStreak[]
  bookmarks       ResourceBookmark[]
  resourceRequests ResourceRequest[]
  counsellorRequests CounsellorRequest[]
  alumniProfile   AlumniProfile?
  admissionDocuments AdmissionDocument[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId, status])
  @@map("student")
}

/// Enrolment links a student to a stream for a given academic year.
model Enrolment {
  id              String   @id @default(uuid()) @db.Uuid
  studentId       String   @db.Uuid
  streamId        String   @db.Uuid
  academicYearId  String   @db.Uuid
  boardingStatus  BoardingStatus @default(DAY)
  enrolledOn      DateTime @default(now())
  withdrawnOn     DateTime?
  withdrawalReason String?

  student         Student  @relation(fields: [studentId], references: [id])
  stream          Stream   @relation(fields: [streamId], references: [id])
  academicYear    AcademicYear @relation(fields: [academicYearId], references: [id])

  @@unique([studentId, academicYearId])
  @@index([streamId])
  @@map("enrolment")
}

model AdmissionDocument {
  id              String   @id @default(uuid()) @db.Uuid
  studentId       String   @db.Uuid
  kind            AdmissionDocumentKind
  assetId         String   @db.Uuid
  notes           String?
  uploadedAt      DateTime @default(now())

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  asset           FileAsset @relation(fields: [assetId], references: [id])

  @@index([studentId, kind])
  @@map("admission_document")
}

model StaffProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  schoolId        String   @db.Uuid
  staffNo         String
  position        String?
  department      String?
  hiredOn         DateTime @db.Date
  endedOn         DateTime?
  isHeadTeacher   Boolean  @default(false)
  isDeputyHead    Boolean  @default(false)
  isBursar        Boolean  @default(false)
  status          StaffStatus @default(ACTIVE)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School   @relation(fields: [schoolId], references: [id])
  courseOfferings CourseOffering[]
  authoredAssignments Assignment[] @relation("AssignmentAuthor")
  markedSubmissions Submission[] @relation("SubmissionMarker")
  reportApprovals ReportCardApproval[]
  streamsLed      Stream[] @relation("StreamFormTeacher")
  leaveRequests   StaffLeaveRequest[]
  cpdEntries      CpdEntry[]
  awardedPoints   HousePointEntry[]
  timetableSlots  TimetableSlot[]

  @@unique([schoolId, staffNo])
  @@index([schoolId, status])
  @@map("staff_profile")
}

model StaffLeaveRequest {
  id              String   @id @default(uuid()) @db.Uuid
  staffId         String   @db.Uuid
  startsOn        DateTime @db.Date
  endsOn          DateTime @db.Date
  reason          String
  status          LeaveStatus @default(PENDING)
  decidedById     String?  @db.Uuid
  decidedAt       DateTime?
  decisionNote    String?
  createdAt       DateTime @default(now())

  staff           StaffProfile @relation(fields: [staffId], references: [id])

  @@index([staffId, status])
  @@map("staff_leave_request")
}

/// A CPD (continuous professional development) log entry — Section 5, feature E.
model CpdEntry {
  id              String   @id @default(uuid()) @db.Uuid
  staffId         String   @db.Uuid
  title           String
  provider        String?
  completedOn     DateTime @db.Date
  hours           Decimal  @db.Decimal(5, 2)
  certificateAssetId String? @db.Uuid
  notes           String?

  staff           StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  certificate     FileAsset?   @relation(fields: [certificateAssetId], references: [id])

  @@index([staffId])
  @@map("cpd_entry")
}

model GuardianProfile {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String   @unique @db.Uuid
  schoolId        String   @db.Uuid
  occupation      String?
  employer        String?
  residentialAddress String?
  workPhone       String?
  preferredChannel CommunicationChannel @default(IN_APP)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  school          School   @relation(fields: [schoolId], references: [id])
  students        StudentGuardian[]

  @@map("guardian_profile")
}

/// Models the relationship between a student and a guardian with explicit
/// access scopes (Section 9 — "a grandparent paying fees but not receiving
/// report cards is a valid and supported arrangement").
model StudentGuardian {
  id              String   @id @default(uuid()) @db.Uuid
  studentId       String   @db.Uuid
  guardianId      String   @db.Uuid
  relationship    GuardianRelationship
  isPrimary       Boolean  @default(false)
  isEmergencyContact Boolean @default(false)
  canViewAcademics Boolean @default(true)
  canViewFees     Boolean  @default(true)
  canPayFees      Boolean  @default(true)
  canMessageStaff Boolean  @default(true)
  canReceiveReports Boolean @default(true)
  createdAt       DateTime @default(now())

  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  guardian        GuardianProfile @relation(fields: [guardianId], references: [id], onDelete: Cascade)

  @@unique([studentId, guardianId])
  @@index([guardianId])
  @@map("student_guardian")
}

// =============================================================================
//  4. ACADEMIC WORKSPACE
// =============================================================================

model Subject {
  id              String   @id @default(uuid()) @db.Uuid
  schoolId        String   @db.Uuid
  code            String
  name            String
  description     String?
  isExamSubject   Boolean  @default(true)
  zimsecCode      String?
  createdAt       DateTime @default(now())

  school          School   @relation(fields: [schoolId], references: [id])
  courseOfferings CourseOffering[]

  @@unique([schoolId, code])
  @@map("subject")
}

/// A subject taught by a specific teacher to a specific stream for a specific
/// year — the unit of "class" in the teacher console.
model CourseOffering {
  id              String   @id @default(uuid()) @db.Uuid
  subjectId       String   @db.Uuid
  streamId        String   @db.Uuid
  primaryTeacherId String  @db.Uuid
  academicYearId  String   @db.Uuid
  createdAt       DateTime @default(now())

  subject         Subject  @relation(fields: [subjectId], references: [id])
  stream          Stream   @relation(fields: [streamId], references: [id])
  primaryTeacher  StaffProfile @relation(fields: [primaryTeacherId], references: [id])
  assignments     Assignment[]
  gradebookEntries GradebookEntry[]
  attendanceRecords AttendanceRecord[]
  resources       Resource[]
  timetableSlots  TimetableSlot[]
  assessmentComponents AssessmentComponent[]

  @@unique([subjectId, streamId, academicYearId])
  @@index([primaryTeacherId])
  @@map("course_offering")
}

/// Weightings — e.g. continuous-assessment 40%, mid-term 20%, end-of-term 40%.
model AssessmentComponent {
  id              String   @id @default(uuid()) @db.Uuid
  courseOfferingId String  @db.Uuid
  label           String
  weightPercent   Decimal  @db.Decimal(5, 2)
  createdAt       DateTime @default(now())

  courseOffering  CourseOffering @relation(fields: [courseOfferingId], references: [id], onDelete: Cascade)
  gradebookEntries GradebookEntry[]

  @@unique([courseOfferingId, label])
  @@map("assessment_component")
}

model Assignment {
  id              String   @id @default(uuid()) @db.Uuid
  courseOfferingId String  @db.Uuid
  termId          String   @db.Uuid
  authorId        String   @db.Uuid
  title           String
  instructions    String
  visibility      AssignmentVisibility @default(STREAM)
  releaseAt       DateTime?
  dueAt           DateTime
  maxMarks        Decimal  @db.Decimal(6, 2)
  latePolicy      LatePolicy @default(PENALISE)
  latePenaltyPercentPerDay Decimal @default(0) @db.Decimal(5, 2)
  acceptLateUntil DateTime?
  allowMultipleAttempts Boolean @default(false)
  status          AssignmentStatus @default(DRAFT)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  courseOffering  CourseOffering @relation(fields: [courseOfferingId], references: [id])
  term            Term     @relation(fields: [termId], references: [id])
  author          StaffProfile @relation("AssignmentAuthor", fields: [authorId], references: [id])
  attachments     AssignmentAttachment[]
  rubrics         Rubric[]
  submissions     Submission[]

  @@index([courseOfferingId, status])
  @@index([dueAt])
  @@map("assignment")
}

model AssignmentAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  assignmentId    String   @db.Uuid
  assetId         String   @db.Uuid
  displayOrder    Int      @default(0)

  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  asset           FileAsset  @relation(fields: [assetId], references: [id])

  @@map("assignment_attachment")
}

model Rubric {
  id              String   @id @default(uuid()) @db.Uuid
  assignmentId    String   @db.Uuid
  criterion       String
  descriptor      String?
  maxPoints       Decimal  @db.Decimal(5, 2)
  displayOrder    Int      @default(0)

  assignment      Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  scores          RubricScore[]

  @@map("rubric")
}

model Submission {
  id              String   @id @default(uuid()) @db.Uuid
  assignmentId    String   @db.Uuid
  studentId       String   @db.Uuid
  attemptNumber   Int      @default(1)
  status          SubmissionStatus @default(DRAFT)
  submittedAt     DateTime?
  lateBy          Int?
  receiptReference String  @unique
  markerId        String?  @db.Uuid
  markedAt        DateTime?
  markAwarded     Decimal? @db.Decimal(6, 2)
  feedbackText    String?
  feedbackAudioAssetId String? @db.Uuid
  returnedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  assignment      Assignment   @relation(fields: [assignmentId], references: [id])
  student         Student      @relation(fields: [studentId], references: [id])
  marker          StaffProfile? @relation("SubmissionMarker", fields: [markerId], references: [id])
  feedbackAudio   FileAsset?   @relation("SubmissionFeedbackAudio", fields: [feedbackAudioAssetId], references: [id])
  attachments     SubmissionAttachment[]
  rubricScores    RubricScore[]
  annotations     SubmissionAnnotation[]

  @@unique([assignmentId, studentId, attemptNumber])
  @@index([studentId, status])
  @@map("submission")
}

model SubmissionAttachment {
  id              String   @id @default(uuid()) @db.Uuid
  submissionId    String   @db.Uuid
  assetId         String   @db.Uuid
  displayOrder    Int      @default(0)

  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  asset           FileAsset  @relation(fields: [assetId], references: [id])

  @@map("submission_attachment")
}

/// PDF/image annotations — teacher comments pinned to coordinates on a page.
model SubmissionAnnotation {
  id              String   @id @default(uuid()) @db.Uuid
  submissionId    String   @db.Uuid
  page            Int
  x               Decimal  @db.Decimal(8, 4)
  y               Decimal  @db.Decimal(8, 4)
  width           Decimal? @db.Decimal(8, 4)
  height          Decimal? @db.Decimal(8, 4)
  kind            AnnotationKind @default(COMMENT)
  text            String?
  colorHex        String?
  createdById     String   @db.Uuid
  createdAt       DateTime @default(now())

  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)

  @@index([submissionId, page])
  @@map("submission_annotation")
}

model RubricScore {
  id              String   @id @default(uuid()) @db.Uuid
  submissionId    String   @db.Uuid
  rubricId        String   @db.Uuid
  points          Decimal  @db.Decimal(5, 2)
  comment         String?

  submission      Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  rubric          Rubric     @relation(fields: [rubricId], references: [id])

  @@unique([submissionId, rubricId])
  @@map("rubric_score")
